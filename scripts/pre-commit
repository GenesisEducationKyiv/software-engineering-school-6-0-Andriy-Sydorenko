#!/usr/bin/env bash
# Pre-commit hook: blocks the commit if the committed mocks would change
# after running `make generate`. Catches stale mocks (interface edited
# without regen) and missing mocks (gen.go line added without regen).
#
# Install with `make install-hooks`. Skip with `git commit --no-verify`.
set -euo pipefail

if ! make verify-generate; then
  echo
  echo "Run 'make generate' and re-stage the changes, then commit again."
  exit 1
fi
