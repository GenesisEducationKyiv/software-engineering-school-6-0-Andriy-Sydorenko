# Server
PORT=9090
ADMIN_ADDR=:9091    # health + /metrics

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=your_password

# Logger
LOG_LEVEL=info  # debug | info | warn | error
LOG_FORMAT=text # json | text

# Message broker
NATS_MAX_DELIVER=5  # Redelivery cap before a message is dead-lettered (must be >= 1)
NATS_ACK_WAIT=30s   # Per-message ack deadline before redelivery (Go duration, must be > 0)
