# Database — provide DATABASE_URL OR the separate DB_* params below (URL wins if set)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=release_notifier
DB_SSLMODE=disable

# Redis — optional. When REDIS_URL is set, GitHub API responses are cached
# for 10 minutes to reduce rate-limit pressure. Leave empty to disable.
# Example: redis://:password@host:6379/0
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Server
PORT=8080

# GitHub API (optional, but 60 req/hr without token vs 5000 with)
GITHUB_TOKEN=

# Email — NOTIFIER-owned
BASE_URL=http://localhost:8080
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USERNAME="your@email.com"
SMTP_PASSWORD="shhhhh"

# Notifier service
NOTIFIER_GRPC_ADDR=:50051
ADMIN_ADDR=:8081
NOTIFIER_ADDR=notifier:50051
INTERNAL_API_TOKEN=dev-internal-token

# Scanner
SCAN_INTERVAL=10m

# Logger
LOG_LEVEL=info  # debug | info | warn | error
LOG_FORMAT=text # json | text
