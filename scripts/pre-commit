#!/usr/bin/env bash
# Pre-commit hook: blocks the commit if the committed mocks would change
# after running `make generate-mocks`. Catches stale mocks (interface edited
# without regen) and missing mocks (codegen directive added without regen).
#
# Install with `make install-hooks`. Skip with `git commit --no-verify`.
set -euo pipefail

if ! make verify-mocks; then
  echo
  echo "Run 'make generate-mocks' and re-stage the changes, then commit again."
  exit 1
fi
